import std::storage::map_slot_hash;
import std::addr::*;
import std::precompile::ecrecover;

const U256_MAX = 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff;

const TOTAL_SUPPLY = 1000000;

const TOTAL_SUPPLY_SLOT = 0;
const BALANCE_SLOT_BASE = 1;
const ALLOWANCE_SLOT_BASE = 2;
const NONCES_SLOT_BASE = 3;

const BALANCE_OF_SELECTOR = 0x70a08231;
const TOTAL_SUPPLY_SELECTOR = 0x18160ddd;
const ALLOWANCE_SELECTOR = 0xdd62ed3e;
const TRANSFER_SELECTOR = 0xa9059cbb;
const APPROVE_SELECTOR = 0x095ea7b3;
const TRANSFER_FROM_SELECTOR = 0x23b872dd;
const DECIMALS_SELECTOR = 0x313ce567;
const NAME_SELECTOR = 0x06fdde03;
const SYMBOL_SELECTOR = 0x95d89b41;
const NONCES_SELECTOR = 0x7ecebe00;
const PERMIT_SELECTOR = 0xd505accf;
const DOMAIN_SEPARATOR_SELECTOR = 0x3644e515;

const EIP712_VERSION_HASH = /* `keccak256("1")` */
    0xc89efdaa54c0f20c7adf612882df0950f5a951637e0307cdcb4c672f298b8bc6;
const EIP712_NAME_HASH = /* `keccak256("Test Token")` */
    0x81e8ad438398ab0d4a2a7ecb159490c091bb27c67ace5181f70084e30fadaea2;
const DOMAIN_TYPEHASH = /* `keccak256("EIP712Domain(string name,string version,uint256 chainId,address verifyingContract)")` */
    0x8b73c3c69bb8fe3d512ecc4cf759cc79239f7b179b0ffacaa9a75d522b39400f;
const PERMIT_TYPEHASH = /* `keccak256("Permit(address owner,address spender,uint256 value,uint256 nonce,uint256 deadline)")` */
    0x6e71edae12b1b97f4d1f60370fef10105fa2faae0126114a169c64845d6126c9;

const TRANSFER_TOPIC = 0xddf252ad1be2c89b69c2b068fc378daa952ba7f163c4a11628f55a4df523b3ef;
const APPROVAL_TOPIC = 0x8c5be1e5ebec7d5bd14f71427d1e84f3dd0314c0f7b2291e5b200ac8c7c3b925;

const PERMIT2 = addr_from_u256(0x000000000022D473030F116dDEE9F6B43aC78BA3);

const INSUFFICIENT_BALANCE_SELECTOR = 0xf4d678b8 /* InsufficientBalance() */;
const INSUFFICIENT_ALLOWANCE_SELECTOR = 0x13be252b /* InsufficientAllowance() */;
const PERMIT2_ALLOWANCE_FIXED = 0x3f68539a /* Permit2AllowanceIsFixedAtInfinity() */;
const PERMIT_EXPIRED = 0x1a15a3cc /* PermitExpired() */;
const INVALID_PERMIT = 0xddafbaef /* InvalidPermit() */;

const balance_slot = fn (owner: addr) u256 {
    map_slot_hash(owner.raw, BALANCE_SLOT_BASE)
};

const nonces_slot = fn (owner: addr) u256 {
    map_slot_hash(owner.raw, NONCES_SLOT_BASE)
};

const u8 = struct { raw: u256 };

const addr_eq = fn (a: addr, b: addr) bool {
    a.raw == b.raw
};

const allowance_slot = fn (owner: addr, spender: addr) u256 {
    comptime {
        if ALLOWANCE_SLOT_BASE > 0xff {
            @compile_error("allowance slot base must fit in one byte");
        }
    }
    let buf = @malloc_uninit(64);
    @mstore32(buf +% 32, ALLOWANCE_SLOT_BASE);
    @mstore32(buf +% 31, spender.raw);
    @mstore32(buf +% (31 - 20), owner.raw);
    @evm_keccak256(buf +% (31 - 20 + 12), 20 + 20 + 1)
};

const emit_transfer = fn (from: addr, to: addr, amount: u256) void {
    let buf = @malloc_uninit(32);
    @mstore32(buf, amount);
    @evm_log3(buf, 32, TRANSFER_TOPIC, from.raw, to.raw);
};

const emit_approval = fn (owner: addr, spender: addr, amount: u256) void {
    let buf = @malloc_uninit(32);
    @mstore32(buf, amount);
    @evm_log3(buf, 32, APPROVAL_TOPIC, owner.raw, spender.raw);
};

const revert_4byte = fn (comptime selector: u256) never {
    if selector >= (1 << 32) {
        @compile_error("error selector must fit in four bytes");
    }
    let buf = @malloc_uninit(32);
    @mstore32(buf, selector);
    @evm_revert(buf +% (32 - 4), 4);
};

const require_4byte = fn (condition: bool, comptime selector: u256) void {
    if !condition {
        revert_4byte(selector);
    }
};

const calldataload_addr = fn (comptime offset: u256) addr {
    let raw = @evm_calldataload(offset);
    if raw >= (1 << 160) {
        @evm_revert(@malloc_uninit(0), 0);
    }
    addr { raw: raw }
};

const calldataload_u8 = fn (comptime offset: u256) u8 {
    let raw = @evm_calldataload(offset);
    if raw >= (1 << 8) {
        @evm_revert(@malloc_uninit(0), 0);
    }
    u8 { raw: raw }
};

const return_word = fn (word: u256) never {
    let buf = @malloc_uninit(32);
    @mstore32(buf, word);
    @evm_return(buf, 32);
};

const compute_domain_separator = fn () u256 {
    let buf = @malloc_uninit(32 * 5);
    @mstore32(buf +% (32 * 0), DOMAIN_TYPEHASH);
    @mstore32(buf +% (32 * 1), EIP712_NAME_HASH);
    @mstore32(buf +% (32 * 2), EIP712_VERSION_HASH);
    @mstore32(buf +% (32 * 3), @evm_chainid());
    @mstore32(buf +% (32 * 4), @evm_address_this());
    @evm_keccak256(buf, 32 * 5)
};

const copy_domain_separator = fn (dst: memptr) void {
    @evm_codecopy(dst, @runtime_length(), 32);
};

init {
    @evm_sstore(TOTAL_SUPPLY_SLOT, TOTAL_SUPPLY);

    let slot = balance_slot(msg_sender());
    @evm_sstore(slot, TOTAL_SUPPLY);
    emit_transfer(addr { raw: 0 }, msg_sender(), TOTAL_SUPPLY);

    let domain_separator = compute_domain_separator();

    let final_runtime_len = @runtime_length() + 32;
    let runtime_buf = @malloc_uninit(final_runtime_len);
    @evm_codecopy(runtime_buf, @runtime_start_offset(), @runtime_length());
    @mstore32(runtime_buf +% @runtime_length(), domain_separator);

    @evm_return(runtime_buf, final_runtime_len);
}

run {
    let selector = @evm_calldataload(0) >> 224;
    if selector == TRANSFER_FROM_SELECTOR {
        let from = calldataload_addr(0x04);
        let to = calldataload_addr(0x24);
        let amount = @evm_calldataload(0x44);
        transfer_from(from, to, amount);
    } else if selector == BALANCE_OF_SELECTOR {
        let owner = calldataload_addr(0x04);
        balance_of(owner);
    } else if selector == TRANSFER_SELECTOR {
        let to = calldataload_addr(0x04);
        let amount = @evm_calldataload(0x24);
        transfer(to, amount);
    } else if selector == APPROVE_SELECTOR {
        let spender = calldataload_addr(0x04);
        let amount = @evm_calldataload(0x24);
        approve(spender, amount);
    } else if selector == PERMIT_SELECTOR {
        let owner =    calldataload_addr(4 + (32 * 0));
        let spender =  calldataload_addr(4 + (32 * 1));
        let value =    @evm_calldataload(4 + (32 * 2));
        let deadline = @evm_calldataload(4 + (32 * 3));
        let v =          calldataload_u8(4 + (32 * 4));
        let r =        @evm_calldataload(4 + (32 * 5));
        let s =        @evm_calldataload(4 + (32 * 6));

        permit(owner, spender, value, deadline, v, r, s);
    } else if selector == ALLOWANCE_SELECTOR {
        let owner = calldataload_addr(0x04);
        let spender = calldataload_addr(0x24);
        allowance(owner, spender);
    } else if selector == NONCES_SELECTOR {
        let owner = calldataload_addr(0x04);
        nonces(owner);
    } else if selector == TOTAL_SUPPLY_SELECTOR {
        total_supply();
    } else if selector == DECIMALS_SELECTOR {
        decimals();
    } else if selector == NAME_SELECTOR {
        name();
    } else if selector == SYMBOL_SELECTOR {
        symbol();
    } else if selector == DOMAIN_SEPARATOR_SELECTOR {
        domain_separator();
    }

    @evm_revert(@malloc_uninit(0), 0);
}

const balance_of = fn (owner: addr) never {
    let slot = balance_slot(owner);
    let balance = @evm_sload(slot);

    return_word(balance);
};

const total_supply = fn () never {
    let supply = @evm_sload(TOTAL_SUPPLY_SLOT);

    return_word(supply);
};

const transfer = fn (to: addr, amount: u256) never {
    transfer_balance(msg_sender(), to, amount);

    return_word(1);
};

const CONSOLE_ADDR = 0x000000000000000000636F6e736F6c652e6c6f67;
const LOG_UINT_SELECTOR = 0xf82c50f1;

const console = (struct { log: function }) {
    log: fn (value: u256) void {
        let buf = @malloc_uninit(64);
        @mstore32(buf, LOG_UINT_SELECTOR);
        @mstore32(buf +% 32, value);
        if !@evm_staticcall(@evm_gas(), CONSOLE_ADDR, buf +% 28, 36, @malloc_uninit(0), 0) {
            @evm_revert(@malloc_uninit(0), 0);
        }
    }
};

const allowance = fn (owner: addr, spender: addr) never {
    let allowance = if addr_eq(spender, PERMIT2) {
        U256_MAX
    } else {
        let slot = allowance_slot(owner, spender);
        @evm_sload(slot)
    };

    return_word(allowance);
};

const approve = fn (spender: addr, amount: u256) never {
    require_4byte(!addr_eq(spender, PERMIT2) or amount == U256_MAX, PERMIT2_ALLOWANCE_FIXED);

    @evm_sstore(allowance_slot(msg_sender(), spender), amount);
    emit_approval(msg_sender(), spender, amount);

    return_word(1);
};

const allowance_consume = fn (owner: addr, amount: u256) bool {
    if addr_eq(msg_sender(), PERMIT2) {
        return true;
    }
    let allowance_slot = allowance_slot(owner, msg_sender());
    let allowance_val = @evm_sload(allowance_slot);
    if allowance_val == U256_MAX {
        return true;
    }
    if allowance_val >= amount {
        @evm_sstore(allowance_slot, allowance_val -% amount);
        return true;
    }
    return false;
};

const transfer_from = fn (from: addr, to: addr, amount: u256) never {
    require_4byte(allowance_consume(from, amount), INSUFFICIENT_ALLOWANCE_SELECTOR);

    transfer_balance(from, to, amount);

    return_word(1);
};

const decimals = fn () never {
    return_word(18);
};

const name = fn () never {
    let buf = @malloc_zeroed(32 * 3);
    @mstore32(buf, 32);
    @mstore32(buf +% 32 +% 10, 0x0a5465737420546f6b656e /* "Test Token" */);
    @evm_return(buf, 32 * 3);
};

const symbol = fn () never {
    let buf = @malloc_zeroed(32 * 3);
    @mstore32(buf, 32);
    @mstore32(buf +% 32 +% 3, 0x03545354 /* "TST" */);
    @evm_return(buf, 32 * 3);
};

const transfer_balance = fn (from: addr, to: addr, amount: u256) void {
    let from_slot = balance_slot(from);
    let balance_from = @evm_sload(from_slot);
    require_4byte(balance_from >= amount, INSUFFICIENT_BALANCE_SELECTOR);
    @evm_sstore(from_slot, balance_from - amount);

    let to_slot = balance_slot(to);
    let balance_to = @evm_sload(to_slot);
    @evm_sstore(to_slot, balance_to + amount);

    emit_transfer(from, to, amount);
};

const hash_permit = fn (
    owner: addr,
    spender: addr,
    value: u256,
    nonce: u256,
    deadline: u256,
) u256 {
    let buf = @malloc_uninit(6 * 32);
    @mstore32(buf +% (0 * 32), PERMIT_TYPEHASH);
    @mstore32(buf +% (1 * 32), owner.raw);
    @mstore32(buf +% (2 * 32), spender.raw);
    @mstore32(buf +% (3 * 32), value);
    @mstore32(buf +% (4 * 32), nonce);
    @mstore32(buf +% (5 * 32), deadline);
    @evm_keccak256(buf, 6 * 32)
};

const erc712_digest = fn (struct_hash: u256) u256 {
    let buf = @malloc_uninit(3 * 32);
    @mstore32(buf +% (0 * 32), 0x1901);
    copy_domain_separator(buf +% (1 * 32));
    @mstore32(buf +% (2 * 32), struct_hash);
    @evm_keccak256(buf +% (32 - 2), 32 + 32 + 2)
};


const permit = fn (
    owner: addr,
    spender: addr,
    value: u256,
    deadline: u256,
    v: u8,
    r: u256,
    s: u256
) never {
    require_4byte(!addr_eq(spender, PERMIT2) or value == U256_MAX, PERMIT2_ALLOWANCE_FIXED);
    require_4byte(@evm_timestamp() <= deadline, PERMIT_EXPIRED);

    let nonce_slot = nonces_slot(owner);
    let nonce = @evm_sload(nonce_slot);

    let permit_struct_hash = hash_permit(owner, spender, value, nonce, deadline);
    let digest = erc712_digest(permit_struct_hash);
    let recovered = ecrecover(digest, v.raw, r, s);
    require_4byte(recovered.is_some and addr_eq(recovered.inner, owner), INVALID_PERMIT);

    @evm_sstore(nonce_slot, nonce +% 1);
    emit_approval(owner, spender, value);
    @evm_sstore(allowance_slot(owner, spender), value);

    @evm_stop();
};

const nonces = fn (owner: addr) never {
    let slot = nonces_slot(owner);
    let nonce = @evm_sload(slot);
    return_word(nonce);
};

const domain_separator = fn () never {
    let buf = @malloc_uninit(32);
    copy_domain_separator(buf);
    @evm_return(buf, 32);
};
