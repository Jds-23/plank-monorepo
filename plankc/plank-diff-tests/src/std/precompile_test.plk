import std::abi::abi_encode;
import std::constructor::return_runtime;
import std::membytes::{membytes, membytes_new, membytes_from_ptr};
import std::precompile::{ecrecover, sha256, ripemd160, modexp};

const ECRECOVER_SELECTOR = 0xa489405c;
const RIPEMD160_SELECTOR = 0x31699b64;
const SHA256_SELECTOR = 0xb32a323d;
const MODEXP_SELECTOR = 0x725782ca;

const BytesResult = struct { data: membytes };

init {
    return_runtime();
}

run {
    let selector = @evm_shr(224, @evm_calldataload(0));
    if @evm_eq(selector, ECRECOVER_SELECTOR) {
        call_ecrecover();
    } else if @evm_eq(selector, SHA256_SELECTOR) {
        call_sha256();
    } else if @evm_eq(selector, RIPEMD160_SELECTOR) {
        call_ripemd160();
    } else if @evm_eq(selector, MODEXP_SELECTOR) {
        call_modexp();
    } else {
        @evm_revert(@malloc_uninit(0), 0);
    }
}

const call_ecrecover = fn () never {
    let hash = @evm_calldataload(4);
    let v = @evm_calldataload(36);
    let r = @evm_calldataload(68);
    let s = @evm_calldataload(100);

    let addr = ecrecover(hash, v, r, s);
    let out = @malloc_uninit(32);
    let unwrapped = if addr.is_some { addr.inner.raw } else { 0 };
    @mstore32(out, unwrapped);
    @evm_return(out, 32);
};

const call_sha256 = fn () never {
    let offset = @evm_calldataload(4) +% 4;
    let data = bytes_from_offset(offset);
    let hash = sha256(data);

    let out = @malloc_uninit(32);
    @mstore32(out, hash);
    @evm_return(out, 32);
};

const call_ripemd160 = fn () never {
    let offset = @evm_calldataload(4) +% 4;
    let data = bytes_from_offset(offset);
    let hash = ripemd160(data);

    let out = @malloc_uninit(32);
    @mstore32(out, hash);
    @evm_return(out, 32);
};

const call_modexp = fn () never {
    let base_offset = @evm_calldataload(4) +% 4;
    let exp_offset = @evm_calldataload(36) +% 4;
    let mod_offset = @evm_calldataload(68) +% 4;

    let base = bytes_from_offset(base_offset);
    let exp = bytes_from_offset(exp_offset);
    let mod = bytes_from_offset(mod_offset);

    let result = modexp(base, exp, mod);
    let out = abi_encode(BytesResult { data: result });
    @evm_return(out.ptr, out.len);
};

const bytes_from_offset = fn (offset: u256) membytes {
    let len = @evm_calldataload(offset);
    let out = membytes_new(len);
    @evm_calldatacopy(out.ptr, offset +% 32, len);

    out
};
